---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// 按分类统计标签频率
const categoryTagCount: Record<string, Record<string, number>> = {};
for (const post of allPosts) {
  const cats = post.data.categories.length > 0 ? post.data.categories : ['其他'];
  for (const cat of cats) {
    if (!categoryTagCount[cat]) categoryTagCount[cat] = {};
    for (const t of post.data.tags) {
      categoryTagCount[cat][t] = (categoryTagCount[cat][t] || 0) + 1;
    }
  }
}

// 每个分类：前5个标签 + 剩余
const categoryData = Object.entries(categoryTagCount).map(([cat, tagMap]) => {
  const sorted = Object.entries(tagMap).sort((a, b) => b[1] - a[1]);
  return { cat, top: sorted.slice(0, 5), more: sorted.slice(5) };
});

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
---
<BaseLayout title="AI 创意工坊" description="AI 驱动的中文内容博客">
  <div class="page-header">
    <h1>AI 创意工坊</h1>
    <p>由 DeerFlow 自动生成，聚焦 AI 应用与工具</p>
  </div>

  {categoryData.length > 0 && (
    <div class="keyword-nav">
      {categoryData.map(({ cat, top, more }) => (
        <div class="keyword-group">
          <span class="keyword-group-label">{cat}</span>
          <div class="keyword-group-tags">
            {top.map(([t]) => (
              <a href={`${base}tags/${t}/`} class="tag">#{t}</a>
            ))}
            {more.length > 0 && (
              <div class="keyword-more-wrap">
                <button class="keyword-more-btn" type="button">更多 +{more.length}</button>
                <div class="keyword-more-dropdown">
                  {more.map(([t]) => (
                    <a href={`${base}tags/${t}/`} class="tag">#{t}</a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  )}

  <ul class="post-list">
    {allPosts.map(post => (
      <li>
        <a href={`${base}blog/${post.slug}/`} class="post-card">
          <div class="post-card-meta">
            <span class="post-date">{formatDate(post.data.date)}</span>
            {post.data.categories[0] && (
              <span class="badge badge-difficulty">{post.data.categories[0]}</span>
            )}
          </div>
          <h2>{post.data.title}</h2>
          {post.data.excerpt && <p class="post-summary">{post.data.excerpt}</p>}
          {post.data.tags.length > 0 && (
            <div class="tag-list">
              {post.data.tags.map(t => <span class="tag">#{t}</span>)}
            </div>
          )}
        </a>
      </li>
    ))}
    {allPosts.length === 0 && (
      <li style="text-align:center;padding:60px 0;color:var(--text-dim);font-family:var(--font-mono)">
        还没有文章，敬请期待。
      </li>
    )}
  </ul>
</BaseLayout>

<script>
  document.querySelectorAll('.keyword-more-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const wrap = btn.closest('.keyword-more-wrap');
      wrap?.classList.toggle('open');
    });
  });
  document.addEventListener('click', () => {
    document.querySelectorAll('.keyword-more-wrap.open').forEach(el => el.classList.remove('open'));
  });
</script>
