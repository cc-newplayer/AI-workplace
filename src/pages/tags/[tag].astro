---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap(p => p.data.tags))];
  return tags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter(p => p.data.tags.includes(tag))
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;
const base = import.meta.env.BASE_URL;

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
---
<BaseLayout title={`#${tag} · AI Blog`} description={`与「${tag}」相关的 ${posts.length} 篇文章`}>
  <a href={base} class="back-link">← 返回首页</a>
  <div class="tag-page-header">
    <h1>#{tag}</h1>
    <span class="count">{posts.length} 篇文章</span>
  </div>

  <ul class="post-list">
    {posts.map(post => (
      <li>
        <a href={`${base}blog/${post.slug}/`} class="post-card">
          <div class="post-card-meta">
            <span>{formatDate(post.data.date)}</span>
            {post.data.categories[0] && (
              <span class="badge badge-difficulty">{post.data.categories[0]}</span>
            )}
          </div>
          <h2>{post.data.title}</h2>
          {post.data.excerpt && <p class="post-summary">{post.data.excerpt}</p>}
          {post.data.tags.length > 0 && (
            <div class="tag-list">
              {post.data.tags.map(t => (
                <span class={`tag ${t === tag ? 'tag-active' : ''}`}>#{t}</span>
              ))}
            </div>
          )}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
