---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string;
  meta_title?: string;
  meta_description?: string;
  categories: string[];
  tags: string[];
  excerpt?: string;
}

const { title, date, meta_title, meta_description, categories, tags, excerpt } = Astro.props;
const base = import.meta.env.BASE_URL;

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<BaseLayout title={meta_title || title} description={meta_description || excerpt} ogTitle={title}>
  <a href={base} class="back-link">← 返回首页</a>
  <article>
    <div class="article-header">
      <div class="article-meta">
        <span>{formatDate(date)}</span>
        {categories.map(c => (
          <span class="badge badge-difficulty">{c}</span>
        ))}
      </div>
      <h1>{title}</h1>
      {tags.length > 0 && (
        <div class="tag-list">
          {tags.map(t => (
            <a href={`${base}tags/${t}/`} class="tag">#{t}</a>
          ))}
        </div>
      )}
    </div>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
