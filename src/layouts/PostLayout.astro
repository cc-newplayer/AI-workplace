---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string;
  meta_title?: string;
  meta_description?: string;
  categories: string[];
  tags: string[];
  excerpt?: string;
}

const { title, date, meta_title, meta_description, categories, tags, excerpt } = Astro.props;
const base = import.meta.env.BASE_URL;

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}

const gradients = [
  'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
  'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',
  'linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)',
];
const coverGradient = gradients[Math.abs(title.charCodeAt(0)) % gradients.length];
---
<BaseLayout title={meta_title || title} description={meta_description} ogTitle={title}>
  <article class="post-page">
    <header class="post-header">
      <div class="post-meta-top">
        {categories.map((c, i) => (
          <>
            {i > 0 && <span class="dot">·</span>}
            <span>{c}</span>
          </>
        ))}
        {categories.length > 0 && <span class="dot">·</span>}
        <time datetime={date}>{formatDate(date)}</time>
      </div>
      <h1 class="post-title">{title}</h1>
      {excerpt && <p class="post-excerpt">{excerpt}</p>}
      {tags.length > 0 && (
        <div class="post-meta">
          <div class="post-tag-list">
            {tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      )}
    </header>

    <div class="post-cover" style={`background: ${coverGradient}`} aria-hidden="true"></div>

    <div class="post-body prose">
      <slot />
    </div>

    <footer class="post-footer">
      <a href={base} class="back-link">← 返回首页</a>
    </footer>
  </article>
</BaseLayout>
