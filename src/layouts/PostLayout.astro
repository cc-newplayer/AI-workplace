---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string;
  meta_title?: string;
  meta_description?: string;
  categories: string[];
  tags: string[];
  excerpt?: string;
}

const { title, date, meta_title, meta_description, categories, tags } = Astro.props;
const base = import.meta.env.BASE_URL;

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<BaseLayout title={meta_title || title} description={meta_description} ogTitle={title}>
  <article class="post-page">
    <header class="post-header">
      <div class="post-meta-top">
        {categories.map(c => (
          <span class="category-chip">{c}</span>
        ))}
      </div>
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={date}>{formatDate(date)}</time>
        {tags.length > 0 && (
          <div class="tag-list">
            {tags.map(t => <span class="tag">#{t}</span>)}
          </div>
        )}
      </div>
    </header>

    <div class="post-cover" aria-hidden="true"></div>

    <div class="post-body prose">
      <slot />
    </div>

    <footer class="post-footer">
      <a href={base} class="back-link">← 返回首页</a>
    </footer>
  </article>
</BaseLayout>
